( to-do )
( Pages )
( 	each page is a fixed number of pointers to strings )
(   the on controller function increments the page pointer then redraws )


( devices )
|00 @System  &vector $2 &pad $6 &r $2 &g $2 &b $2
|10 @Console $8 &write $2
|20 @Screen  &vector $2 &width $2 &height $2 &pad $2 &x $2 &y $2 &addr $2 &pixel $1 &sprite $1
|30 @Audio0     [ &vector $2 &position $2 &output $1 &pad   $3 &adsr   $2 &length $2 &addr $2 &volume $1 &pitch $1 ]
|80 @Controller [ &vector $2 &button $1 &key $1 ]

( macros )
%EMIT { .Console/write DEO } ( char -- )
%EMIT2 { DUP2 SWP EMIT EMIT }
%INIT-X { #0008 .Screen/x DEO2 } ( -- )
%INIT-Y { #0008 .Screen/y DEO2 } ( -- )
%8ADD-X { .Screen/x DEI2 #0008 ADD2 .Screen/x DEO2 } ( -- )
%9ADD-X { .Screen/x DEI2 #0009 ADD2 .Screen/x DEO2 } ( -- )
%8ADD-Y { .Screen/y DEI2 #0008 ADD2 .Screen/y DEO2 } ( -- )
%9ADD-Y { .Screen/y DEI2 #0009 ADD2 .Screen/y DEO2 } ( -- )
%DRAW { .Screen/pixel DEO } ( color -- )
( increment X screen co-ordinate )
%INC-X { .Screen/x DEI2 INC2 .Screen/x DEO2 } ( -- )
( increment X by N )
%ADD-X { .Screen/x DEI2 ADD2 .Screen/x DEO2 } ( N -- ) 
( decrement X by N )
%SUB-X { #00 SWP .Screen/x DEI2 SWP2 SUB2 .Screen/x DEO2 } ( N -- ) 
%SUB-X2 { .Screen/x DEI2 SWP2 SUB2 .Screen/x DEO2 } ( N -- ) 
( increment Y screen co-ordinate )
%INC-Y { .Screen/y DEI2 INC2 .Screen/y DEO2 } ( -- )
( increment Y by N )
%ADD-Y { .Screen/y DEI2 ADD2 .Screen/y DEO2 } ( N -- ) 
( decrement Y by N )
%SUB-Y { #00 SWP .Screen/y DEI2 SWP2 SUB2 .Screen/y DEO2 } ( N -- ) 


%GET-NOTE { #00 SWP ;melody ADD2 LDA }
%MELODY_LENGTH { #80 }
%SINE_LENGTH { #a0 }
%SAMPLE_LENGTH { #0100 }

( variables )

|0000

@timer     $1
@progress  $1
@sine-ctr  $1
@current-slide $2

( main program )
|0100
      ( set system colors )
      #4cff .System/r DEO2
      #4dfd .System/g DEO2
      #4cf0 .System/b DEO2

      
      ;on-controller .Controller/vector DEO2
      ;on-frame .Screen/vector DEO2

      	( setup synth )
      #0248 .Audio0/adsr DEO2
      ;bse .Audio0/addr DEO2
      #0100 .Audio0/length DEO2
      #dd .Audio0/volume DEO ( TODO: turn ON )
      ;draw-slide JSR2
BRK

@on-controller ( -- )
	;draw-slide JSR2
BRK

@draw-slide ( -- )
  ( set system colors )
  #4cff .System/r DEO2
  #4dfd .System/g DEO2
  #4cf0 .System/b DEO2
  .current-slide LDZ2 LDA2 ,&ds-continue JCN
  ;slide-1 .current-slide STZ2 
  &ds-continue
    ( draw yellow bar )
    #0000 .Screen/x DEO2
    #0000 .Screen/y DEO2
    #0010 .Screen/width DEI2 #03 ;draw-rect JSR2
    ( stedin header )
    #0010 .Screen/x DEO2
    #0004 .Screen/y DEO2
    ;stedin-header #0c ;print JSR2
    ( draw background )
    #0000 .Screen/x DEO2
    #0010 .Screen/y DEO2
    .Screen/height DEI2 .Screen/width DEI2 #02 ;draw-rect JSR2
    ( get current slide )
    #0020 .Screen/x DEO2
    #0030 .Screen/y DEO2
    .current-slide LDZ2 LDA2 #08 ;print JSR2
    #0020 .Screen/x DEO2
    #0060 .Screen/y DEO2
    .current-slide LDZ2 #0002 ADD2 LDA2 #08 ;print JSR2
    #0020 .Screen/x DEO2
    #0080 .Screen/y DEO2
    .current-slide LDZ2 #0004 ADD2 LDA2 #08 ;print JSR2
    #0020 .Screen/x DEO2
    #00a0 .Screen/y DEO2
    .current-slide LDZ2 #0006 ADD2 LDA2 #08 ;print JSR2
    #0020 .Screen/x DEO2
    #00c0 .Screen/y DEO2
    .current-slide LDZ2 #0008 ADD2 LDA2 #08 ;print JSR2
    #0020 .Screen/x DEO2
    #00e0 .Screen/y DEO2
    .current-slide LDZ2 #000a ADD2 LDA2 #08 ;print JSR2
    #0020 .Screen/x DEO2
    #0100 .Screen/y DEO2
    .current-slide LDZ2 #000c ADD2 LDA2 #08 ;print JSR2
    
    ( move pointer for next time ) 
    .current-slide LDZ2 #000e ADD2 .current-slide STZ2
JMP2r

@on-frame ( -> )
  ( we check for the slide after the one we really want )
  ( because the current slide pointer is incremented after display )
  .current-slide LDZ2 ;slide-8 EQU2 #01 JCN [ BRK ]
  .System/r DEI2 #0001 ADD2 #00 .timer LDZ ADD2 .System/r DEO2
  .System/g DEI2 #0001 ADD2 .System/g DEO2
  .System/b DEI2 #0003 ADD2 .System/b DEO2
	( incr ) .timer LDZ INC .timer STZ 
	( skip ) .timer LDZ #08 EQU #01 JCN [ BRK ]
  #0000 
  &sine-loop
    DUP2 DUP2 ;saw ADD2 LDA .sine-ctr LDZ #00 SWP ;sine ADD2 LDA ADD ROT ROT 
    ;bse ADD2 STA
    ( increment sine offset, with mask )
    .sine-ctr LDZ INC INC INC INC INC SINE_LENGTH #01 SUB AND .sine-ctr STZ
    INC2 DUP2 SAMPLE_LENGTH LTH2 ,&sine-loop JCN
  POP2

	.progress LDZ 
	( play note )    DUP GET-NOTE .Audio0/pitch DEO
	( incr )  INC MELODY_LENGTH #01 SUB AND .progress STZ
	#00 .timer STZ
BRK


( get a sprite address from an ASCII value )
@get-char ( ascii -- sprite-addr* )
  #20 ( space char, start of font table )
  SUB #00 SWP #30 SFT2 ;char-space ADD2
JMP2r

( print a string, getting the correct char at each step )
@print ( string-addr* color -- )
  ,&print-color STR
  ,&string-addr STR2
  &p_loop
    ,&string-addr LDR2 LDA DUP #00 EQU ,&print-end JCN
    ;get-char JSR2 .Screen/addr DEO2
    ,&print-color LDR .Screen/sprite DEO 9ADD-X
    ,&string-addr LDR2 INC2
    ,&string-addr STR2 ,&p_loop JMP
&print-end
POP
JMP2r
&string-addr $2
&print-color $1

@draw-rect ( height^ width^ color -- )
    ,&dr_color STR
    ,&dr_width STR2 
    #0000
    &dr_loop
        ,&dr_width LDR2 ,&dr_color LDR ;draw-line JSR2
        INC-Y ,&dr_width LDR2 SUB-X2
        INC2 GTHk2 ,&dr_loop JCN
    POP2 POP2
JMP2r
&dr_width $2
&dr_color $1

@draw-line ( length^ color -- )
     ,&dl_color STR
     #0000
     &dl_loop
        ,&dl_color LDR DRAW INC-X
        INC2 GTHk2 ,&dl_loop JCN
     POP2 POP2
JMP2r    
&dl_color $1

