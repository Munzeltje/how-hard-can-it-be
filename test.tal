( devices )
|00 @System  &vector $2 &pad $6 &r $2 &g $2 &b $2
|10 @Console $8 &write $2
|20 @Screen  &vector $2 &width $2 &height $2 &pad $2 &x $2 &y $2 &addr $2 &pixel $1 &sprite $1

( macros )
%EMIT { .Console/write DEO } ( char -- )
%EMIT2 { DUP2 SWP EMIT EMIT }
%INIT-X { #0008 .Screen/x DEO2 } ( -- )
%INIT-Y { #0008 .Screen/y DEO2 } ( -- )
%8ADD-X { .Screen/x DEI2 #0008 ADD2 .Screen/x DEO2 } ( -- )
%9ADD-X { .Screen/x DEI2 #0009 ADD2 .Screen/x DEO2 } ( -- )
%8ADD-Y { .Screen/y DEI2 #0008 ADD2 .Screen/y DEO2 } ( -- )
%9ADD-Y { .Screen/y DEI2 #0009 ADD2 .Screen/y DEO2 } ( -- )

( main program )
|0100
      ( set system colors )
      #4cff .System/r DEO2
      #4dfd .System/g DEO2
      #4cf0 .System/b DEO2

      ( set x,y coordinates )
      INIT-X INIT-Y
      LIT "A ;get-char JSR2 .Screen/addr DEO2
      #03 .Screen/sprite DEO 9ADD-Y
      
      LIT "! ;get-char JSR2 .Screen/addr DEO2
      #03 .Screen/sprite DEO 9ADD-Y

      ;letterc .Screen/addr DEO2
      #01 .Screen/sprite DEO 9ADD-Y

      ;letterd .Screen/addr DEO2
      #01 .Screen/sprite DEO 9ADD-Y

      ;lettere .Screen/addr DEO2
      #01 .Screen/sprite DEO 9ADD-Y 

      ;letterf .Screen/addr DEO2
      #01 .Screen/sprite DEO 9ADD-Y

      ;letterg .Screen/addr DEO2
      #01 .Screen/sprite DEO 9ADD-Y

      ;letterh .Screen/addr DEO2
      #01 .Screen/sprite DEO 9ADD-Y

      ;letteri .Screen/addr DEO2
      #01 .Screen/sprite DEO 9ADD-Y

      ;letterj .Screen/addr DEO2
      #01 .Screen/sprite DEO 9ADD-Y

      ;letterk .Screen/addr DEO2
      #01 .Screen/sprite DEO 9ADD-Y
      
      ;letterr .Screen/addr DEO2
      #01 .Screen/sprite DEO 9ADD-Y
      
      ;letters .Screen/addr DEO2
      #01 .Screen/sprite DEO 9ADD-Y
      
      ;lettert .Screen/addr DEO2
      #01 .Screen/sprite DEO 9ADD-Y
      
      ;letteru .Screen/addr DEO2
      #01 .Screen/sprite DEO 9ADD-Y
      
      ;letterv .Screen/addr DEO2
      #01 .Screen/sprite DEO 9ADD-Y
      
      ;letterw .Screen/addr DEO2
      #01 .Screen/sprite DEO 9ADD-Y
      
      ;letterx .Screen/addr DEO2
      #01 .Screen/sprite DEO 9ADD-Y
      
      ;lettery .Screen/addr DEO2
      #01 .Screen/sprite DEO 9ADD-Y

      ;letterz .Screen/addr DEO2
      #01 .Screen/sprite DEO 9ADD-Y 

      ;digit0 .Screen/addr DEO2
      #01 .Screen/sprite DEO 9ADD-Y 

      ;digit1 .Screen/addr DEO2
      #01 .Screen/sprite DEO 9ADD-Y 

      ;digit2 .Screen/addr DEO2
      #01 .Screen/sprite DEO 9ADD-Y 

      ;digit3 .Screen/addr DEO2
      #01 .Screen/sprite DEO 9ADD-Y 

      ;digit4 .Screen/addr DEO2
      #01 .Screen/sprite DEO 9ADD-Y 

      ;digit5 .Screen/addr DEO2
      #01 .Screen/sprite DEO 9ADD-Y 

