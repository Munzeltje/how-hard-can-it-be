( devices )
|00 @System  &vector $2 &pad $6 &r $2 &g $2 &b $2
|10 @Console $8 &write $2
|20 @Screen  &vector $2 &width $2 &height $2 &pad $2 &x $2 &y $2 &addr $2 &pixel $1 &sprite $1
|30 @Audio0     [ &vector $2 &position $2 &output $1 &pad   $3 &adsr   $2 &length $2 &addr $2 &volume $1 &pitch $1 ]
|80 @Controller [ &vector $2 &button $1 &key $1 ]

( macros )
%EMIT { .Console/write DEO } ( char -- )
%EMIT2 { DUP2 SWP EMIT EMIT }
%INIT-X { #0008 .Screen/x DEO2 } ( -- )
%INIT-Y { #0008 .Screen/y DEO2 } ( -- )
%8ADD-X { .Screen/x DEI2 #0008 ADD2 .Screen/x DEO2 } ( -- )
%9ADD-X { .Screen/x DEI2 #0009 ADD2 .Screen/x DEO2 } ( -- )
%8ADD-Y { .Screen/y DEI2 #0008 ADD2 .Screen/y DEO2 } ( -- )
%9ADD-Y { .Screen/y DEI2 #0009 ADD2 .Screen/y DEO2 } ( -- )
%GET-NOTE { #00 SWP ;melody ADD2 LDA }
%MELODY_LENGTH { #08 }


( variables )

|0000

@timer     $1
@progress  $1

( main program )
|0100
      ( set system colors )
      #4cff .System/r DEO2
      #4dfd .System/g DEO2
      #4cf0 .System/b DEO2

      ( set x,y coordinates )
      #0000 .Screen/x DEO2
      #0000 .Screen/y DEO2

      ;test_string ;print JSR2
      
      ;on-controller .Controller/vector DEO2
      ;on-frame .Screen/vector DEO2

(      ;on-note-0-finish .Audio0/vector DEO2 )

      	( setup synth )
      #0208 .Audio0/adsr DEO2
      ;saw .Audio0/addr DEO2
      #0100 .Audio0/length DEO2
      #dd .Audio0/volume DEO ( TODO: turn ON )
BRK

@on-controller ( -- )
  #0040 .Screen/x DEO2
  #0040 .Screen/y DEO2
  ;message ;print JSR2
BRK

@on-frame ( -> )
	( incr ) .timer LDZ INC .timer STZ 
	( skip ) .timer LDZ #10 EQU #01 JCN [ BRK ]
	.progress LDZ 
	( play note )    DUP GET-NOTE .Audio0/pitch DEO
	( incr )  INC MELODY_LENGTH #01 SUB AND .progress STZ
	#00 .timer STZ
BRK


( get a sprite address from an ASCII value )
@get-char ( ascii -- sprite-addr* )
  #20 ( space char, start of font table )
  SUB #00 SWP #30 SFT2 ;char-space ADD2
JMP2r

( print a string, getting the correct char at each step )
@print ( string-addr* -- )
  ,&string-addr STR2
  &p_loop
    ,&string-addr LDR2 LDA DUP #00 EQU ,&print-end JCN
    ;get-char JSR2 .Screen/addr DEO2
    #03 .Screen/sprite DEO 9ADD-X
    ,&string-addr LDR2 INC2
    ,&string-addr STR2 ,&p_loop JMP
&print-end
POP
JMP2r
&string-addr $2



@test_string "ABCDEFGHIJKLMNOPQRSTUVWXYZ 20 "0123456789!.? 00 
@message "GREETINGS 20 "FROM 20 "TEAM 20 "HOW 20 "HARD 20 "CAN 20 "IT 20 "BE? 00


